{
  "name": "model-router",
  "version": "0.6.0",
  "kit": "theonekit-model-router",
  "description": "Multi-model subagent delegation — route tasks to cheap models via OpenCode Go",
  "required": true,
  "dependencies": {},
  "crossKitDependencies": {},
  "files": {
    "scripts": [
      "mr-delegate.sh",
      "post-install.sh",
      "mr-doctor.sh"
    ],
    "hooks": [
      "mr-spawn-guard.cjs",
      "mr-metrics.cjs",
      "mr-update-check.cjs",
      "mr-doctor-check.cjs",
      "mr-telemetry.cjs"
    ],
    "agents": [
      "model-router-mr-explorer-fast.md",
      "model-router-mr-doc-scout.md",
      "model-router-mr-doc-writer.md",
      "model-router-mr-coder-cheap.md",
      "model-router-mr-reviewer-deep.md",
      "model-router-mr-tester.md"
    ],
    "rules": [
      "mr-transparent-routing.md"
    ],
    ".": [
      "providers-config.json",
      "model-capabilities.md",
      "t1k-config-mr.json",
      "settings.json"
    ]
  },
  "postInstall": "scripts/post-install.sh",
  "doctor": "scripts/mr-doctor.sh",
  "skills": [
    "t1k-delegate"
  ],
  "agents": [],
  "activation": {
    "sessionBaseline": [],
    "mappings": [
      {
        "keywords": [
          "delegate to cheap model",
          "use cheap model",
          "delegate to opencode",
          "use opencode go"
        ],
        "skills": [
          "t1k-delegate"
        ]
      },
      {
        "keywords": [
          "explore cheap",
          "find files cheap",
          "explore with opencode"
        ],
        "skills": [
          "t1k-delegate"
        ]
      },
      {
        "keywords": [
          "review cheap",
          "security review cheap",
          "deep review cheap"
        ],
        "skills": [
          "t1k-delegate"
        ]
      },
      {
        "keywords": [
          "code cheap",
          "implement cheap",
          "boilerplate"
        ],
        "skills": [
          "t1k-delegate"
        ]
      },
      {
        "keywords": [
          "audit docs",
          "scan documentation"
        ],
        "skills": [
          "t1k-delegate"
        ]
      },
      {
        "keywords": [
          "write docs cheap",
          "update docs cheap"
        ],
        "skills": [
          "t1k-delegate"
        ]
      },
      {
        "keywords": [
          "run tests cheap",
          "test with cheap model"
        ],
        "skills": [
          "t1k-delegate"
        ]
      }
    ]
  },
  "routingOverlay": {
    "explorer": "mr-explorer-fast",
    "reviewer": "mr-reviewer-deep",
    "doc-writer": "mr-doc-writer",
    "doc-scout": "mr-doc-scout",
    "coder": "mr-coder-cheap",
    "tester": "mr-tester"
  },
  "_origin": {
    "kit": "theonekit-model-router",
    "repository": "The1Studio/theonekit-model-router",
    "module": "model-router",
    "protected": false
  }
}
